{
  "name": "reusable-toolkit",
  "version": "1.0.0",
  "description": "Pragmatic Digital shared toolkit monorepo",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm -r --parallel dev",
    "lint": "eslint . --ext .ts,.tsx,.js,.jsx",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "changeset:publish": "changeset publish",
    "storybook": "pnpm --filter @pragmatic/ui storybook",
    "build-storybook": "pnpm --filter @pragmatic/ui build-storybook"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.1",
    "@eslint/js": "^9.0.0",
    "@pragmatic/eslint-config": "workspace:*",
    "@storybook/test": "^8.6.15",
    "@tailwindcss/postcss": "^4.3.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/ui": "^4.1.10",
    "autoprefixer": "^10.5.2",
    "eslint": "^9.0.0",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.16",
    "prettier": "^3.2.5",
    "tailwindcss": "^4.3.2",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8.63.0",
    "vitest": "^4.1.10"
  },
  "dependencies": {
    "@radix-ui/react-dropdown-menu": "^2.1.20",
    "@radix-ui/react-navigation-menu": "^1.2.18",
    "@radix-ui/react-slot": "^1.3.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1"
  }
}
