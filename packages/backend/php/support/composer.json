{
    "name": "pragmatic/php-support",
    "description": "Framework-agnostic PHP utilities and helpers",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Pragmatic Digital",
            "email": "hello@pragmatic.digital"
        }
    ],
    "autoload": {
        "psr-4": {
            "Pragmatic\\Support\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Pragmatic\\Support\\Tests\\": "tests/"
        }
    },
    "require": {
        "php": "^8.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "phpstan/phpstan": "^1.10",
        "squizlabs/php_codesniffer": "^3.7"
    },
    "scripts": {
        "test": "phpunit",
        "phpcs": "phpcs --standard=../../tooling/php/phpcs.xml src",
        "phpstan": "phpstan analyse -c ../../tooling/php/phpstan.neon.dist"
    },
    "extra": {
        "branch-alias": {
            "dev-main": "1.x-dev"
        }
    }
}
