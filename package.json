{
  "name": "reusable-toolkit",
  "version": "1.0.0",
  "description": "Pragmatic Digital shared toolkit monorepo",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm -r --parallel dev",
    "lint": "eslint . --ext .ts,.tsx,.js,.jsx",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "changeset:publish": "changeset publish",
    "storybook": "pnpm --filter @pragmatic/ui storybook",
    "build-storybook": "pnpm --filter @pragmatic/ui build-storybook"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.1",
    "@eslint/js": "^9.0.0",
    "@pragmatic/eslint-config": "workspace:*",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.2.5",
    "typescript": "^5.3.3"
  }
}
